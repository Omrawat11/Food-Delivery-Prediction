# pyenv
#   For a library or app, you might want to share your .python-version if using pyenv
#   Keep it commented out unless you want to use it
#.python-version

# pipenv
#   According to pypa/pipenv#1185, Pipfile.lock should be part of upstream dependency,
#   but microservices, apps, and dev envs should keep it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock should be part of upstream dependency,
#   but microservices, apps, and dev envs should keep it.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock should be part of upstream dependency,
#   but microservices, apps, and dev envs should keep it.
#.pdm.toml
#.pdm-plugins/
#pdm.lock

# PEP 582; vertical environments project templates, e.g. personal settings, etc.
__pypackages__/

